{
  "name": "hora_tagplus_notificacao_whatsapp",
  "description": "Dedupe/auditoria das notificações WhatsApp de NFe aprovada / pedido confirmado da HORA.",
  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "tipo",
      "type": "varchar(10)",
      "description": "PEDIDO | NFE",
      "nullable": false
    },
    {
      "name": "ref_id",
      "type": "integer",
      "description": "HoraVenda.id ou HoraTagPlusNfeEmissao.id",
      "nullable": false
    },
    {
      "name": "numero",
      "type": "varchar(30)",
      "description": "numero NFe (NFE) ou id pedido (PEDIDO)"
    },
    {
      "name": "cliente_nome",
      "type": "varchar(255)"
    },
    {
      "name": "vendedor_nome",
      "type": "varchar(120)"
    },
    {
      "name": "loja_nome",
      "type": "varchar(120)"
    },
    {
      "name": "valor",
      "type": "numeric(15,2)"
    },
    {
      "name": "enviado_grupo",
      "type": "boolean",
      "nullable": false,
      "default": false
    },
    {
      "name": "enviado_vendedor",
      "type": "boolean",
      "description": "NULL = não havia vendedor a notificar"
    },
    {
      "name": "status",
      "type": "varchar(15)",
      "description": "PENDENTE/PROCESSANDO/ENVIADO/PARCIAL/ERRO/IGNORADO",
      "nullable": false,
      "default": "PENDENTE"
    },
    {
      "name": "erro",
      "type": "text"
    },
    {
      "name": "tentativas",
      "type": "integer",
      "nullable": false,
      "default": 0
    },
    {
      "name": "anexou_pdf",
      "type": "boolean",
      "nullable": false,
      "default": false
    },
    {
      "name": "enviado_em",
      "type": "timestamp"
    },
    {
      "name": "criado_em",
      "type": "timestamp",
      "description": "Data de criação",
      "nullable": false
    }
  ],
  "unique_constraints": [
    [
      "tipo",
      "ref_id"
    ]
  ],
  "indices": [
    {
      "name": "idx_hora_tagplus_notif_status",
      "columns": [
        "status"
      ],
      "unique": false
    }
  ]
}
