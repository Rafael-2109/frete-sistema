      "name": "id",
      "type": "bigint",
      "description": "Primary key"
    },
    {
      "name": "peca_id",
      "type": "integer",
      "description": "FK → assai_peca.id",
      "nullable": false
    },
    {
      "name": "tipo",
      "type": "varchar(40)",
      "nullable": false
    },
    {
      "name": "quantidade",
      "type": "numeric(15,3)",
      "nullable": false
    },
    {
      "name": "delta_almoxarifado",
      "type": "numeric(15,3)",
      "nullable": false,
      "default": 0
    },
    {
      "name": "chassi_origem",
      "type": "varchar(50)"
    },
    {
      "name": "chassi_destino",
      "type": "varchar(50)"
    },
    {
      "name": "pendencia_id",
      "type": "integer",
      "description": "FK → assai_pendencia.id"
    },
    {
      "name": "compra_item_id",
      "type": "integer",
      "description": "FK → assai_peca_compra_item.id"
    },
    {
      "name": "custo_unitario",
      "type": "numeric(15,4)"
    },
    {
      "name": "custo_total",
      "type": "numeric(15,2)"
    },
    {
      "name": "receita_unitaria",
      "type": "numeric(15,4)"
    },
    {
      "name": "receita_total",
      "type": "numeric(15,2)"
    },
    {
      "name": "operador_id",
      "type": "integer",
      "description": "FK → usuarios.id"
    },
    {
      "name": "ocorrido_em",
      "type": "timestamp",
      "nullable": false
    },
    {
      "name": "observacao",
