{
  "name": "pessoal_categorias",
  "description": "Tabela pessoal_categorias",
  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "nome",
      "type": "varchar(100)",
      "nullable": false
    },
    {
      "name": "grupo",
      "type": "varchar(100)",
      "nullable": false
    },
    {
      "name": "icone",
      "type": "varchar(50)"
    },
    {
      "name": "ordem_exibicao",
      "type": "integer",
      "default": 0,
      "description": "Campo legado, nao mapeado no model Python. Usar 'grupo, nome' para ordenar."
    },
    {
      "name": "ativa",
      "type": "boolean",
      "default": true
    },
    {
      "name": "criado_em",
      "type": "timestamp",
      "description": "Data de criação"
    }
  ],
  "unique_constraints": [
    [
      "grupo",
      "nome"
    ]
  ]
}
