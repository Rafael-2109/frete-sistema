      "description": "VALOR, PESO, VAN, etc."
    },
    {
      "name": "nome_tabela",
      "type": "varchar(100)"
    },
    {
      "name": "valor_kg",
      "type": "float"
    },
    {
      "name": "percentual_valor",
      "type": "float"
    },
    {
      "name": "frete_minimo_valor",
      "type": "float"
    },
    {
      "name": "frete_minimo_peso",
      "type": "float"
    },
    {
      "name": "icms",
      "type": "float"
    },
    {
      "name": "percentual_gris",
      "type": "float"
    },
    {
      "name": "pedagio_por_100kg",
      "type": "float"
    },
    {
      "name": "valor_tas",
      "type": "float"
    },
    {
      "name": "percentual_adv",
      "type": "float"
    },
    {
      "name": "percentual_rca",
      "type": "float"
    },
    {
      "name": "valor_despacho",
      "type": "float"
    },
    {
      "name": "valor_cte",
      "type": "float"
    },
    {
      "name": "icms_incluso",
      "type": "boolean",
      "default": false
    },
    {
      "name": "icms_destino",
      "type": "float",
      "description": "ICMS da cidade de destino"
