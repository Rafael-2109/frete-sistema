      "description": "FK → usuarios.id",
      "nullable": false
    },
    {
      "name": "transportadora_id",
      "type": "integer",
      "description": "FK → transportadoras.id",
      "nullable": false
    },
    {
      "name": "status",
      "type": "varchar(20)",
      "nullable": false,
      "default": "Em Aberto"
    },
    {
