    {
      "name": "gris_minimo",
      "type": "float",
      "description": "Valor mínimo de GRIS",
      "default": 0
    },
    {
      "name": "adv_minimo",
      "type": "float",
      "description": "Valor mínimo de ADV",
      "default": 0
    },
    {
      "name": "icms_proprio",
      "type": "float",
      "description": "ICMS próprio da tabela"
    }
