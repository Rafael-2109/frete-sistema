{
  "name": "embarque_itens",
  "description": "Itens individuais dentro de um embarque. Campos: embarque_id, separacao_lote_id, cnpj_cliente, cliente, pedido, nota_fiscal, peso, valor, volumes, pallets, uf_destino, cidade_destino. Para co-passageiros: SELECT * FROM embarque_itens WHERE embarque_id = X.",
  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "embarque_id",
      "type": "integer",
      "description": "FK → embarques.id",
      "nullable": false
    },
    {
      "name": "separacao_lote_id",
      "type": "varchar(50)",
      "description": "VARCHAR ex: LOTE_20251004_032844_195 (NAO e integer)"
    },
    {
      "name": "local_cd",
      "type": "varchar(20)",
      "description": "CD de expedicao do item: VICTORIO_MARCHEZINE | TENENTE_MARQUES",
      "nullable": false,
      "default": "VICTORIO_MARCHEZINE"
    },
    {
      "name": "cnpj_cliente",
      "type": "varchar(20)",
      "description": "CNPJ do cliente — fonte de dedup na cotação e no rateio do frete"
    },
    {
      "name": "cliente",
      "type": "varchar(120)",
      "description": "Nome fantasia do cliente",
      "nullable": false
    },
    {
      "name": "pedido",
      "type": "varchar(50)",
      "description": "Nosso número do pedido",
      "nullable": false
    },
    {
      "name": "protocolo_agendamento",
      "type": "varchar(50)",
      "description": "Senha única do comprovante de agendamento"
    },
    {
      "name": "data_agenda",
      "type": "varchar(10)",
      "description": "Data do agendamento no cliente"
    },
    {
      "name": "agendamento_confirmado",
      "type": "boolean",
      "description": "Status de confirmação do agendamento",
      "default": false
    },
    {
      "name": "hora_agendamento",
      "type": "time",
      "description": "Horario do agendamento (HH:MM) — exclusivo CarVia (Nacom deixa NULL)"
    },
    {
      "name": "nota_fiscal",
      "type": "varchar(20)",
      "description": "Número da NF"
    },
    {
      "name": "volumes",
      "type": "integer",
      "description": "Qtd de volumes (possivelmente não utilizada)"
    },
    {
      "name": "peso",
      "type": "float",
      "description": "Peso bruto (fisico) do item"
    },
    {
      "name": "peso_cubado",
      "type": "float",
      "description": "Peso cubado (CarVia motos); NULL = usar peso"
    },
    {
      "name": "valor",
      "type": "float",
      "description": "Valor do item"
    },
    {
      "name": "pallets",
      "type": "float",
      "description": "Pallets TEÓRICOS (via CadastroPalletizacao)"
    },
    {
      "name": "status",
      "type": "varchar(20)",
      "description": "'ativo' ou 'cancelado'",
      "nullable": false,
      "default": "ativo"
    },
    {
      "name": "uf_destino",
      "type": "varchar(2)",
      "description": "UF de destino do frete",
      "nullable": false
    },
    {
      "name": "cidade_destino",
      "type": "varchar(100)",
      "description": "Cidade de destino do frete",
      "nullable": false
    },
    {
      "name": "cotacao_id",
      "type": "integer",
      "description": "FK → cotacoes.id"
    },
    {
      "name": "modalidade",
      "type": "varchar(50)",
      "description": "FRETE PESO ou FRETE VALOR (quando tipo_carga=FRACIONADA)"
    },
    {
      "name": "tabela_nome_tabela",
      "type": "varchar(100)",
      "description": "Nome da tabela dado pela transportadora que está realizando o frete"
    },
    {
      "name": "tabela_valor_kg",
      "type": "float",
      "description": "Preço por kg da transportadora"
    },
    {
      "name": "tabela_percentual_valor",
      "type": "float",
      "description": "Custo de frete relativo ao valor da mercadoria (%)"
    },
    {
      "name": "tabela_frete_minimo_valor",
      "type": "float",
      "description": "Valor mínimo do frete"
    },
    {
      "name": "tabela_frete_minimo_peso",
      "type": "float",
      "description": "Peso mínimo para cálculo do frete"
    },
    {
      "name": "tabela_icms",
      "type": "float",
      "description": "% de ICMS quando há tratativa comercial (substitui o icms_destino fixo)"
    },
    {
      "name": "tabela_percentual_gris",
      "type": "float",
      "description": "% de GRIS (Gerenciamento de Risco)"
    },
    {
      "name": "tabela_pedagio_por_100kg",
      "type": "float",
      "description": "Valor de pedágio cobrado por fração de 100kg"
    },
    {
      "name": "tabela_valor_tas",
      "type": "float",
      "description": "Taxa fixa de administração do SEFAZ (TAS)"
    },
    {
      "name": "tabela_percentual_adv",
      "type": "float",
      "description": "% de ADV (seguro cobrado)"
    },
    {
      "name": "tabela_percentual_rca",
      "type": "float",
      "description": "% de RCA (seguro fluvial)"
    },
    {
      "name": "tabela_valor_despacho",
      "type": "float",
      "description": "Taxa fixa por CNPJ despachado pela transportadora contratada"
    },
    {
      "name": "tabela_valor_cte",
      "type": "float",
      "description": "Taxa fixa por CT-e emitido pela transportadora contratada"
    },
    {
      "name": "tabela_icms_incluso",
      "type": "boolean",
      "description": "Flag: ICMS já incluso no valor ou precisa ser adicionado",
      "default": false
    },
    {
      "name": "icms_destino",
      "type": "float",
      "description": "% de ICMS fixo por região"
    },
    {
      "name": "tabela_gris_minimo",
      "type": "float",
      "description": "Valor mínimo de GRIS",
      "default": 0
    },
    {
      "name": "tabela_adv_minimo",
      "type": "float",
      "description": "Valor mínimo de ADV",
      "default": 0
    },
    {
      "name": "tabela_icms_proprio",
      "type": "float",
      "description": "ICMS próprio da tabela"
    },
    {
      "name": "erro_validacao",
      "type": "varchar(500)",
      "description": "Armazena erros como \"CNPJ_DIFERENTE\", etc."
    },
    {
      "name": "provisorio",
      "type": "boolean",
      "description": "Flag: pedido CarVia ainda sem NF (provisório)",
      "nullable": false,
      "default": false
    },
    {
      "name": "carvia_cotacao_id",
      "type": "integer",
      "description": "ID da cotação para pedidos da CarVia"
    },
    {
      "name": "nf_pallet_cliente",
      "type": "varchar(20)",
      "description": "NF remessa para cliente"
    },
    {
      "name": "qtd_pallet_cliente",
      "type": "float",
      "description": "Qtd na NF cliente",
      "default": 0
    },
    {
      "name": "nf_pallet_referencia",
      "type": "varchar(20)",
      "description": "Qual NF de pallet cobre esta venda"
    },
    {
      "name": "nf_pallet_origem",
      "type": "varchar(10)",
      "description": "'EMBARQUE' ou 'ITEM'"
    }
  ],
  "foreign_keys": [
    {
      "column": "embarque_id",
      "references": "embarques.id"
    },
    {
      "column": "cotacao_id",
      "references": "cotacoes.id"
    }
  ],
  "indices": [
    {
      "name": "idx_ei_cnpj_cliente",
      "columns": [
        "cnpj_cliente"
      ],
      "unique": false
    },
    {
      "name": "idx_ei_embarque_status",
      "columns": [
        "embarque_id",
        "status"
      ],
      "unique": false
    },
    {
      "name": "idx_ei_nota_fiscal",
      "columns": [
        "nota_fiscal"
      ],
      "unique": false
    },
    {
      "name": "idx_ei_uf_destino",
      "columns": [
        "uf_destino"
      ],
      "unique": false
    },
    {
      "name": "ix_embarque_itens_carvia_cotacao_id",
      "columns": [
        "carvia_cotacao_id"
      ],
      "unique": false
    },
    {
      "name": "ix_embarque_itens_separacao_lote_id",
      "columns": [
        "separacao_lote_id"
      ],
      "unique": false
    }
  ]
}
