{
  "name": "agent_step",
  "description": "Telemetria por turno (1 linha por turn). step_uid = '{session_id}:{turn_seq}' — o numero do turno vem de split_part(step_uid,':',2)::int (NAO ha coluna turn_seq). session_id e' coluna sem FK: DELETE da sessao NAO apaga os steps (use LEFT JOIN). outcome_signal (JSONB) tem judge.evidencia (truncado em 500c).",
  "fields": [
    {
      "name": "id",
      "type": "bigint",
      "description": "Primary key"
    },
    {
      "name": "step_uid",
      "type": "text",
      "nullable": false
    },
    {
      "name": "session_id",
      "type": "text"
    },
    {
      "name": "user_id",
      "type": "integer"
    },
    {
      "name": "channel",
      "type": "text",
      "description": "'web' | 'teams'"
    },
    {
      "name": "model",
      "type": "text"
    },
    {
      "name": "input_tokens",
      "type": "integer",
      "nullable": false,
      "default": 0
    },
    {
      "name": "output_tokens",
      "type": "integer",
      "nullable": false,
      "default": 0
    },
    {
      "name": "tools_used",
      "type": "json"
    },
    {
      "name": "outcome_signal",
      "type": "json"
    },
    {
      "name": "outcome_effective_count",
      "type": "integer"
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "description": "Data de criação",
      "nullable": false
    }
  ],
  "indices": [
    {
      "name": "ix_agent_step_created_at",
      "columns": [
        "created_at"
      ],
      "unique": false
    },
    {
      "name": "ix_agent_step_session_id",
      "columns": [
        "session_id"
      ],
      "unique": false
    },
    {
      "name": "ix_agent_step_user_id",
      "columns": [
        "user_id"
      ],
      "unique": false
    }
  ]
}
