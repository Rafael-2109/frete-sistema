{
  "name": "inventario_contagem_item",
  "description": "1 linha = 1 stock.quant (location_name + cod + lote) de uma contagem cíclica.",
  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "contagem_id",
      "type": "integer",
      "description": "FK → inventario_contagem.id",
      "nullable": false
    },
    {
      "name": "location_name",
      "type": "varchar(120)",
      "nullable": false
    },
    {
      "name": "location_id",
      "type": "integer",
      "description": "ID Odoo do location (determinismo)"
    },
    {
      "name": "local_tipo",
      "type": "varchar(20)",
      "description": "Estoque / Indisponivel"
    },
    {
      "name": "is_migracao",
      "type": "boolean",
      "default": false
    },
    {
      "name": "cod_produto",
      "type": "varchar(50)",
      "nullable": false
    },
    {
      "name": "nome_produto",
      "type": "varchar(200)"
    },
    {
      "name": "lote",
      "type": "varchar(60)",
      "description": "'' = sem lote (sentinela)",
      "nullable": false,
      "default": ""
    },
    {
      "name": "company_id",
      "type": "integer",
      "description": "1 FB / 4 CD / 5 LF"
    },
    {
      "name": "qtd_esperada",
      "type": "numeric(15,3)",
      "description": "saldo Odoo no T0",
      "default": 0
    },
    {
      "name": "reservado_esperado",
      "type": "numeric(15,3)",
      "description": "reserved no T0",
      "default": 0
    },
    {
      "name": "contagem",
      "type": "numeric(15,3)",
      "description": "nullable até preencher"
    },
    {
      "name": "ajuste",
      "type": "numeric(15,3)",
      "description": "contagem − qtd_esperada (Odoo)",
      "default": 0
    },
    {
      "name": "ajuste_inventario",
      "type": "numeric(15,3)",
      "description": "coluna AJUSTE (Confronto)",
      "nullable": false,
      "default": 0
    },
    {
      "name": "classe",
      "type": "varchar(20)",
      "description": "NORMAL/RESERVA_FANTASMA/NEGATIVO/LOTE_NOVO/SEM_AJUSTE"
    },
    {
      "name": "obs",
      "type": "varchar(300)"
    }
  ],
  "foreign_keys": [
    {
      "column": "contagem_id",
      "references": "inventario_contagem.id"
    }
  ],
  "unique_constraints": [
    [
      "contagem_id",
      "location_name",
      "cod_produto",
      "lote"
    ]
  ],
  "indices": [
    {
      "name": "ix_inventario_contagem_item_cod_produto",
      "columns": [
        "cod_produto"
      ],
      "unique": false
    },
    {
      "name": "ix_inventario_contagem_item_contagem_id",
      "columns": [
        "contagem_id"
      ],
      "unique": false
    }
  ]
}
