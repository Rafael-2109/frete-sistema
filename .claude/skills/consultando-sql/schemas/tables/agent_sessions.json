{
  "name": "agent_sessions",
  "description": "Sessao do agente (1 linha por conversa). session_id = UUID interno nosso. JSONB 'data' contem as chaves (NAO sao colunas): channel ('web'/'teams'), sdk_session_id (junta ao transcript cru em claude_session_store), messages (array do historico produto), subagent_costs.entries (custo por subagente), forked_from, plan, deliberation_log, s3_archive. JSONB 'summary' contem: resumo_geral, topicos_abordados, ferramentas_usadas, tarefas_pendentes, alertas, acoes_usuario, pedidos_mencionados, decisoes_tomadas, perfil_signals. Filtrar canal: data->>'channel'='teams'. Para o que a sessao EXECUTOU (Bash/scripts/tools), use a tool mcp__sessions__get_session_transcript em vez de SQL cru. admin_only.",
  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "session_id",
      "type": "varchar(255)",
      "nullable": false
    },
    {
      "name": "user_id",
      "type": "integer",
      "description": "FK → usuarios.id"
    },
    {
      "name": "agente",
      "type": "varchar(20)",
      "nullable": false,
      "default": "web"
    },
    {
      "name": "title",
      "type": "varchar(200)"
    },
    {
      "name": "message_count",
      "type": "integer",
      "default": 0
    },
    {
      "name": "total_cost_usd",
      "type": "numeric(10,6)",
      "default": 0
    },
    {
      "name": "last_message",
      "type": "text"
    },
    {
      "name": "model",
      "type": "varchar(100)"
    },
    {
      "name": "data",
      "type": "json"
    },
    {
      "name": "summary",
      "type": "json",
      "description": "Resumo estruturado (JSONB)"
    },
    {
      "name": "summary_updated_at",
      "type": "timestamp",
      "description": "Quando foi gerado"
    },
    {
      "name": "summary_message_count",
      "type": "integer",
      "description": "message_count quando gerado",
      "default": 0
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "description": "Data de criação"
    },
    {
      "name": "updated_at",
      "type": "timestamp",
      "description": "Última atualização"
    }
  ],
  "foreign_keys": [
    {
      "column": "user_id",
      "references": "usuarios.id"
    }
  ],
  "indices": [
    {
      "name": "ix_agent_sessions_agente",
      "columns": [
        "agente"
      ],
      "unique": false
    },
    {
      "name": "ix_agent_sessions_session_id",
      "columns": [
        "session_id"
      ],
      "unique": true
    },
    {
      "name": "ix_agent_sessions_user_id",
      "columns": [
        "user_id"
      ],
      "unique": false
    }
  ],
  "admin_only": true
}
