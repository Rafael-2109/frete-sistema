      "columns": [
        "despesa_id"
      ],
      "unique": false
    },
    {
      "name": "ix_carvia_coletas_status",
      "columns": [
        "status"
      ],
      "unique": false
    },
    {
      "name": "ix_carvia_coletas_transportadora_id",
      "columns": [
        "transportadora_id"
      ],
      "unique": false
    }
  ]
}
