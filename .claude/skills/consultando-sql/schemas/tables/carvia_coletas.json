  "fields": [
    {
      "name": "id",
      "type": "integer",
      "description": "Primary key"
    },
    {
      "name": "contratado_nome",
      "type": "varchar(255)"
    },
    {
      "name": "transportadora_id",
      "type": "integer",
      "description": "FK → transportadoras.id"
    },
    {
      "name": "placa",
      "type": "varchar(10)"
    },
    {
      "name": "valor_coleta",
      "type": "numeric(15,2)",
      "description": "custo pago ao contratado (-> CarviaDespesa)"
    },
    {
      "name": "local_cd",
      "type": "varchar(20)",
      "description": "Destino: VICTORIO_MARCHEZINE | TENENTE_MARQUES",
      "nullable": false,
      "default": "VICTORIO_MARCHEZINE"
    },
    {
      "name": "data_prevista",
      "type": "date"
    },
    {
      "name": "data_coletada",
      "type": "boolean",
      "nullable": false,
      "default": false
    },
    {
      "name": "data_coletada_em",
      "type": "timestamp",
      "description": "BRT naive"
    },
    {
      "name": "despesa_id",
      "type": "integer",
      "description": "FK → carvia_despesas.id"
    },
    {
      "name": "status",
      "type": "varchar(20)",
      "nullable": false,
      "default": "RASCUNHO"
    },
    {
      "name": "observacoes",
      "type": "text"
    },
    {
      "name": "criado_por",
      "type": "varchar(150)"
    },
    {
      "name": "criado_em",
      "type": "timestamp",
      "description": "Data de criação"
    },
    {
      "name": "atualizado_em",
      "type": "timestamp",
      "description": "Última atualização"
    }
  ],
  "foreign_keys": [
