# =============================================================================
# PLUGGY OPEN FINANCE — variaveis de ambiente
# =============================================================================
# Adicione estas variaveis no .env local e no Render (srv-d13m38vfte5s738t6p60).
# Observacao: PLUGGY_CLIENT_ID e PLUGGY_CLIENT_SECRET ja estao configurados.
#
# Apenas PLUGGY_WEBHOOK_SECRET foi gerado nesta implementacao.
# =============================================================================

# Credenciais Pluggy Developer (dashboard.pluggy.ai) — JA CONFIGURADAS
# PLUGGY_CLIENT_ID=xxxx
# PLUGGY_CLIENT_SECRET=xxxx
# PLUGGY_API_KEY=xxxx  # opcional; fallback se Redis indisponivel

# Segredo para validar assinatura HMAC SHA256 dos webhooks Pluggy
# GERADO via: openssl rand -hex 32
PLUGGY_WEBHOOK_SECRET=a63ff3a65372b22d6be07b29c4402c88b901576bb1b567945dc1ea0a37238f65

# Incluir connectors sandbox no widget (true em dev, false em producao)
PLUGGY_INCLUDE_SANDBOX=false

# URL publica do webhook — Pluggy posta eventos aqui
PLUGGY_WEBHOOK_URL=https://sistema-fretes.onrender.com/pessoal/pluggy/webhook

# Host da API (nao precisa trocar)
PLUGGY_API_HOST=https://api.pluggy.ai



