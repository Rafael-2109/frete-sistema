# =====================================================
# TEMPLATE DE CONFIGURAÇÃO PARA PRODUÇÃO NO RENDER.COM
# =====================================================
# ⚠️ ESTE É UM ARQUIVO TEMPLATE - NÃO USAR DIRETAMENTE!
# Configure as variáveis no Dashboard do Render.com
# Este arquivo serve apenas como referência.
# =====================================================

# Redis do Render (usar o Internal URL fornecido pelo Render)
# REDIS_URL=<seu-redis-internal-url>

# Database PostgreSQL (já configurado automaticamente pelo Render)
# DATABASE_URL é fornecido automaticamente pelo Render

# Credenciais do Portal Atacadão (IMPORTANTE: Configurar no Render Dashboard)
# ATACADAO_USUARIO=<seu_usuario_producao>
# ATACADAO_SENHA=<sua_senha_producao>

# Credenciais Odoo (OBRIGATÓRIO: Configurar no Render Dashboard)
# ODOO_URL=https://odoo.nacomgoya.com.br
# ODOO_DATABASE=odoo-17-ee-nacomgoya-prd
# ODOO_USERNAME=<seu_email_odoo>
# ODOO_API_KEY=<sua_api_key_odoo>

# Configurações de Worker
RQ_WORKER_TTL=300  # 5 minutos
RQ_RESULT_TTL=86400  # 24 horas
RQ_DEFAULT_TIMEOUT=1800  # 30 minutos

# Flask em produção
FLASK_ENV=production
FLASK_DEBUG=0
ENVIRONMENT=production

# =====================================================
# CTe Cancelamento Outlook 365 (Step 18 — 2026-04-09)
# =====================================================
# Automacao de leitura de XMLs de cancelamento de CTe vindos
# de pasta do Outlook 365 via Microsoft Graph API.
# Ver: .claude/plans/temporal-exploring-biscuit.md
#
# Pre-requisitos no Azure AD:
# 1. Criar novo App Registration dedicado (NAO reaproveitar o do bot Teams)
# 2. API Permission: Microsoft Graph > Application > Mail.Read
# 3. Admin consent concedido no tenant
# 4. Criar Client Secret (guardar o "Value", nao o "Secret ID")
#
# Feature flag — DEFAULT OFF. So ligar apos configurar credenciais.
# CTE_CANCELAMENTO_ENABLED=false
#
# Microsoft Graph API (novo app registration dedicado)
# GRAPH_TENANT_ID=<tenant_guid>
# GRAPH_CLIENT_ID=<client_guid_novo_app>
# GRAPH_CLIENT_SECRET=<secret_value_novo_app>
#
# Caixa de email e pasta (nome exato, case-sensitive)
# GRAPH_MAILBOX_UPN=fiscal@nacomgoya.com.br
# GRAPH_FOLDER_NAME=CTe Cancelados
#
# Limites
# CTE_CANCELAMENTO_MAX_EMAILS=100

# Segurança (OBRIGATÓRIO: Gerar chave segura!)
# Gere com: python -c 'import secrets; print(secrets.token_hex(32))'
# SECRET_KEY=<sua_chave_secreta_gerada>